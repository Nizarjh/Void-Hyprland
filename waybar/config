{
  "layer": "top",
  "position": "top",
  "height": 38,
  "hide_on_fullscreen": true,
  "spacing": 3,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["custom/updates", "network", "battery", "cpu", "memory", "pulseaudio", "custom/wallpaper", "custom/power"],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "all-outputs": true,
    "sort-by-number": true
  },
  "persistent-workspaces": {
    "*": 5 // This keeps 1-5 visible at all times
},

  "clock": {
	  "format": "{:%H:%M}"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "󰝟 Muted",
    "format-icons": {
        "headphone": " ",
        "headset": " ",
        "phone": " ",
        "portable": " ",
        "car": " ",
        "default": [" ", " "]
    },
    "on-click": "pavucontrol"
},

"memory": {
    "interval": 5,
    "format": "  {}%",
    "max-length": 10,
    "tooltip-format": "Memory Used: {used:0.1f}G / {total:0.1f}G",
    "on-click": "kitty -e btop"
},

  "network": {
      "format-wifi": "  {essid} ({signalStrength}%)",
      "format-ethernet": "󰈀  Ethernet",
      "format-disconnected": "⚠  Disconnected",
      "on-click": "kitty -e nmtui",
      "tooltip": true,
      "interval": 3
    },

  "cpu": {
	  "format": "   {usage}%",
	  "interval": 3
  },

  "custom/mem": {
    "format": "  {}%",
    "interval": 5,
    "exec": "free -m | awk '/Mem:/ {print int($3/$2 * 100)}'",
    "on-click": "kitty -e btop"
},

  "battery": {
	  "format": "󰁹 {capacity}%",
	  "interval": 10
  },

  "custom/pipewire": {
    "exec": "wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2 * 100)\"%\"}'",
    "interval": 1,
    "format": "   {}",
    "on-click": "pavucontrol",
    "signal": 1
  },

  "custom/power": {
	  "format": "⏻",
	  "tooltip": false,
    "on-click": "~/.config/waybar/scripts/powermenu.fish"
  },

  "custom/updates": {
    "format": "{}",
    "exec": "/home/fraggi/.config/waybar/scripts/check-updates.sh",
    "interval": 3600,
    "on-click": "kitty -e fish -c 'sudo xbps-install -Su; fish'",
    "tooltip": false
},

  "custom/wallpaper": {
    "format": "󰸉 ",
    "on-click": "~/.config/waybar/scripts/wall-change.fish",
    "tooltip": false
},

 }
